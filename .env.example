# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,backend
TIME_ZONE=Asia/Seoul
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Database
DB_NAME=community_db
DB_USER=admin
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Vultr Object Storage
AWS_ACCESS_KEY_ID=your-vultr-access-key
AWS_SECRET_ACCESS_KEY=your-vultr-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_ENDPOINT_URL=https://ewr1.vultrobjects.com
AWS_S3_REGION_NAME=ewr1
USE_S3_STORAGE=True

# PortOne
PORTONE_API_KEY=your-portone-api-key
PORTONE_API_SECRET=your-portone-secret

# Coupang Seller Open API
COUPANG_ACCESS_KEY=your-coupang-access-key
COUPANG_SECRET_KEY=your-coupang-secret-key
COUPANG_VENDOR_ID=your-coupang-vendor-id
COUPANG_BASE_URL=https://api-gateway.coupang.com

# Notification Delivery
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
NOTIFICATION_EMAIL_FROM=no-reply@yourdomain.com
NOTIFICATION_KAKAO_WEBHOOK_URL=https://your-kakao-relay.example/webhook
NOTIFICATION_SMS_WEBHOOK_URL=https://your-sms-relay.example/webhook
NOTIFICATION_DELIVERY_TIMEOUT=8

# Next.js
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://yourdomain.com/ws
